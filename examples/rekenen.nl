// Variabelen en rekenen
stel a = 10, b = 3;

zeg "a =", a;
zeg "b =", b;
zeg "a + b =", a + b;
zeg "a - b =", a - b;
zeg "a * b =", a * b;
zeg "a / b =", a / b;
zeg "a % b =", a % b;

// String optelling
stel naam = "Neder";
stel land = "land";
zeg naam + land;

// Booleans en niets
stel vlag = waar;
stel leeg = niets;
zeg vlag, leeg;

